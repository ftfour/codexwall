HOST=127.0.0.1
PORT=8787
DATA_DIR=/opt/codexwall/server/data

ADMIN_USER=admin
ADMIN_PASSWORD=change-this-long-password

# Optional. Collector runs this command and expects JSON on stdout.
# Keep it empty until you confirm the exact Codex CLI command that returns limits.
# Example shape expected from stdout:
# {"five_hour_percent_left":63,"five_hour_resets_at":"2026-07-06T18:27:00+03:00","weekly_percent_left":28,"weekly_resets_at":"2026-07-10T14:20:00+03:00","updated_at":"2026-07-06T16:09:00+03:00"}
CODEX_LIMITS_COMMAND=

# Optional token for POST /internal/limits if you later want to push JSON from another trusted process.
INTERNAL_TOKEN=change-this-internal-token

# Collector mode:
# - app-server: starts `codex app-server --listen stdio://` and calls account/rateLimits/read.
# - command: runs CODEX_LIMITS_COMMAND and expects final wallpaper JSON on stdout.
CODEX_COLLECTOR_MODE=app-server
CODEX_APP_SERVER_COMMAND=codex
CODEX_APP_SERVER_ARGS=app-server
CODEX_APP_SERVER_TIMEOUT_MS=30000
